# MongoDB URI — НЕ указывайте имя БД, т.к. в коде к URI добавляется /quickblog
# Пример локально: mongodb://localhost:27017
MONGODB_URI=mongodb://localhost:27017

# JWT secret для подписи токенов
JWT_SECRET=change_this_to_a_strong_random_secret

# Админские креды (используются в adminLogin)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=supersecretpassword

# ImageKit (используются в server/configs/imageKit.js)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io